# Copy to .env and adjust. Read by app/config.py (pydantic-settings).

# Postgres connection (psycopg3 driver). Used by the app and Alembic.
BOS_DATABASE_URL=postgresql+psycopg://bos:bos@localhost:5432/bos

# App
BOS_ENV=dev
BOS_LOG_LEVEL=INFO
BOS_API_V1_PREFIX=/api/v1

# Rate limiting (requests per minute per client IP; 0 disables)
BOS_RATE_LIMIT_PER_MINUTE=120

# Low-stock: how far below threshold before we stop re-firing an alert
# (advisory only — never blocks a sale). See services/stock.py.
BOS_LOW_STOCK_RENOTIFY=false

# --- auth (Phase 2) ---
# REQUIRED in production. Generate a strong value, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
BOS_JWT_SECRET=dev-only-insecure-secret-change-me-in-production
BOS_JWT_EXPIRE_MINUTES=720
BOS_PIN_MIN_LENGTH=4
BOS_PIN_MAX_LENGTH=8

# Browser origins allowed to call the API (the web dashboard), comma-separated.
# Set to the deployed dashboard URL in production. Tablet app is unaffected.
BOS_CORS_ORIGINS=http://localhost:5173,http://localhost:4173
